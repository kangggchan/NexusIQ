# NexusIQ environment — copy to .env and fill in values
# .env is gitignored; this file must contain only placeholders

# ── OpenAI (used by legacy GraphRAG CLI only — not needed for Ollama mode) ───
OPENAI_API_KEY=<your-openai-api-key>

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_BACKEND_URL=http://localhost:8000

# ── Agent model overrides (optional) ─────────────────────────────────────────
# MODEL_ORCHESTRATOR=llama3.1:8b
# MODEL_GRAPH=qwen2.5:7b
# MODEL_INCIDENT=llama3.1:8b
# MODEL_RISK=gemma3:12b
# MODEL_EMBEDDING=nomic-embed-text

# ── Neo4j Aura ────────────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<your-neo4j-password>
NEO4J_DATABASE=neo4j

# ── ChromaDB Cloud ────────────────────────────────────────────────────────────
CHROMA_CLOUD_HOST=<region>.gcp.trychroma.com
CHROMA_API_KEY=<your-chroma-api-key>
CHROMA_TENANT=<your-tenant-id>
CHROMA_DATABASE=nexusiq

# ── FastAPI backend ───────────────────────────────────────────────────────────
# BACKEND_PORT=8000
# LOG_LEVEL=info
